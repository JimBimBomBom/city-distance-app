{
  "name": "@xfilipnamefilip/cds-client",
  "version": "1.0.0",
  "description": "Official client library for City Distance Service API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "build:bun": "bun build src/index.ts --outdir dist --format esm && bun build src/index.ts --outdir dist --format cjs",
    "test": "jest",
    "test:bun": "bun test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ci": "npm run backend:start && npm run test:e2e && npm run backend:stop",
    "backend:start": "docker-compose -f docker-compose.test.yml up -d && node scripts/wait-for-backend.js",
    "backend:start:win": "powershell -ExecutionPolicy Bypass -File scripts/start-backend.ps1",
    "backend:stop": "docker-compose -f docker-compose.test.yml down",
    "backend:logs": "docker-compose -f docker-compose.test.yml logs -f",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "city",
    "distance",
    "geolocation",
    "api-client"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.19.33",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jest": "^29.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "axios-retry": "^4.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
