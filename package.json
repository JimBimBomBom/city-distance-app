{
  "name": "@xfilipnamefilip/cds-client",
  "version": "1.3.0",
  "description": "Browser & Node.js client library for City Distance Service API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "browser": "dist/index.global.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm,iife --global-name CDS --dts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "city",
    "distance",
    "geolocation",
    "api-client"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.19.33",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
